{
  lib,
  stdenv,
  fetchFromGitHub,
  fetchurl,
  cmake,
  boost,
  python3,
  openssl,
  which,
  wget,
  curl,
  zip,
  nixsgx,
  makeWrapper,
}:
if stdenv.hostPlatform.isx86_64 && stdenv.hostPlatform.isLinux then
  import ./x86_64-linux.nix {
    inherit
      lib
      stdenv
      fetchFromGitHub
      fetchurl
      cmake
      boost
      python3
      openssl
      which
      wget
      curl
      zip
      nixsgx
      makeWrapper
      ;
  }
else
  import ./portable.nix {
    inherit
      lib
      stdenv
      fetchFromGitHub
      openssl
      curl
      ;
  }
